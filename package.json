{
  "name": "vocabmaxx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integ": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:unit",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:reset": "dotenv -e .env.local -- drizzle-kit drop && pnpm db:push",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@sentry/nextjs": "^9.22.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.43.1",
    "lucide-react": "^0.510.0",
    "next": "15.3.3",
    "postgres": "^3.4.5",
    "posthog-js": "^1.247.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.5.1",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.7",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.2",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "msw": "^2.8.6",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "typescript-eslint": "^8.60.1",
    "vitest": "^3.2.3"
  }
}
