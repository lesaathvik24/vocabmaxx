# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=         # server-only, definition_cache writes + cron
DATABASE_URL=                      # Prod runtime: Transaction Pooler (port 6543). postgresql://postgres.{ref}:{pw}@aws-0-{region}.pooler.supabase.com:6543/postgres
SUPABASE_TEST_DB_URL=              # Integration tests: separate Supabase project + Session Pooler (port 5432). Same URI format with :5432

# LLM — DeepSeek (word definition fallback)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google OAuth — also configure in Supabase dashboard: Auth → Providers → Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email
RESEND_API_KEY=

# Cron auth
CRON_SECRET=

# Observability
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
